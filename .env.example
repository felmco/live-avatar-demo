# HeyGen API Configuration
# Get your API key from: https://app.liveavatar.com/developers
HEYGEN_API_KEY=

# Avatar ID to use (use a public avatar or one from your account)
# Find public avatars at: https://api.liveavatar.com/v1/avatars/public
HEYGEN_AVATAR_ID=

# Your avatar's voice ID
# Get from: https://app.liveavatar.com/voices
HEYGEN_VOICE_ID=

# Your avatar's context ID (LLM persona configuration)
# Get from: https://app.liveavatar.com/context
HEYGEN_CONTEXT_ID=

# Set to "true" to use sandbox mode (free, but only the "Wayne" sandbox avatar works)
HEYGEN_SANDBOX=false
